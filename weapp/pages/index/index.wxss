.index-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--gold);
  letter-spacing: 8rpx;
  text-shadow: 4rpx 4rpx 8rpx rgba(0,0,0,0.5);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--gold-light);
  opacity: 0.8;
}

.characters-preview {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.char-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--black-light);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 20rpx;
  min-width: 120rpx;
}

.char-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.char-name {
  font-size: 24rpx;
  color: var(--gold-light);
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  max-width: 480rpx;
}

.action-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
}

.version {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: var(--text-light);
  opacity: 0.6;
}

/* 难度选择 */
.difficulty-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.difficulty-item {
  border: 2rpx solid var(--gold-light);
  border-radius: 12rpx;
  padding: 20rpx;
  background: var(--black-light);
  opacity: 0.7;
}

.difficulty-item.selected {
  border-color: var(--gold);
  background: rgba(201, 162, 39, 0.15);
  opacity: 1;
}

.diff-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--red);
  margin-bottom: 8rpx;
}

.diff-desc {
  font-size: 26rpx;
  color: var(--text);
  margin-bottom: 8rpx;
}

.diff-params {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 设置 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--gold-light);
  font-size: 30rpx;
  color: var(--text);
}

.ad-removed {
  color: var(--gold);
}
