<!-- 商铺页面：去广告、道具 -->
<view class="container shop-container">
  <view class="shop-header">
    <view class="shop-title">皇家商铺</view>
    <view class="shop-subtitle">支持贞观之治，去除烦扰</view>
  </view>

  <view class="products">
    <view class="product-card {{noAds ? 'purchased' : ''}}">
      <view class="product-icon">🚫</view>
      <view class="product-info">
        <view class="product-name">永久去广告</view>
        <view class="product-desc">移除所有激励视频和 Banner 广告，享受纯净朝政体验</view>
        <view class="product-price">¥6.00</view>
      </view>
      <button 
        class="btn {{noAds ? 'btn-disabled' : 'btn-primary'}}" 
        bindtap="purchaseRemoveAds"
        disabled="{{noAds}}"
      >
        {{noAds ? '已购买' : '立即购买'}}
      </button>
    </view>
  </view>

  <view class="shop-footer">
    <text>购买后可在所有设备同步权益</text>
    <text>如遇问题请联系客服</text>
  </view>
</view>
