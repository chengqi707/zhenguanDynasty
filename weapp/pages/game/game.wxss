.game-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  position: relative;
}

/* 顶部状态栏 */
.header-bar {
  background: linear-gradient(180deg, #2a2a2a 0%, #1f1f1f 100%);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  color: var(--gold-light);
}

.day-info {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.day-label {
  font-size: 28rpx;
}

.day-number {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--red);
  margin: 0 8rpx;
}

.stage-info {
  font-size: 26rpx;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.stability-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stability-label {
  font-size: 24rpx;
  white-space: nowrap;
}

.stability-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gold);
  min-width: 40rpx;
  text-align: right;
}

/* 角色面板 */
.characters-panel {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

@media (max-width: 700px) {
  .characters-panel {
    grid-template-columns: repeat(2, 1fr);
  }
}

.character-card {
  background: var(--paper);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  position: relative;
}

.character-card.deceased {
  opacity: 0.75;
  background: #e8e4d8;
  border-color: #999;
}

.character-card.selected {
  border-color: var(--red);
  box-shadow: 0 0 12rpx rgba(178, 34, 34, 0.3);
}

.char-portrait {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
  border: 2rpx solid var(--gold);
}

.char-emoji {
  font-size: 40rpx;
}

.char-name {
  font-weight: bold;
  font-size: 26rpx;
  color: var(--text);
  margin-bottom: 4rpx;
}

.char-title {
  font-size: 20rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-light);
  min-width: 60rpx;
  text-align: left;
}

.stat-bar {
  flex: 1;
  height: 10rpx;
  background: #e0d8c8;
  border-radius: 6rpx;
  overflow: hidden;
}

.stat-fill {
  height: 100%;
  transition: width 0.5s ease;
}

.favor-fill { background: linear-gradient(90deg, #8b1a1a, #c9a227); }
.power-fill { background: linear-gradient(90deg, #6b4c2a, #8b6914); }
.ability-fill { background: linear-gradient(90deg, #2c5aa0, #4a90d9); }

.stat-value {
  font-size: 20rpx;
  color: var(--text);
  min-width: 40rpx;
  text-align: right;
}

/* 游戏区域 */
.game-area {
  background: var(--paper);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.event-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.event-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--red);
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid var(--gold-light);
  padding-bottom: 16rpx;
}

.event-desc {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  flex: 1;
  overflow-y: auto;
  margin-bottom: 16rpx;
}

.event-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.year-badge {
  background: var(--gold);
  color: var(--black);
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.storyline-badge {
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-btn {
  text-align: left;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 晚间决策 */
.night-section {
  background: var(--paper);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.phase-title {
  text-align: center;
  font-size: 32rpx;
  color: var(--red);
  margin-bottom: 20rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.night-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

@media (max-width: 500px) {
  .night-actions {
    grid-template-columns: 1fr;
  }
}

.action-card {
  background: #fffef8;
  border: 2rpx solid var(--gold-light);
  border-radius: 12rpx;
  padding: 20rpx;
}

.action-name {
  font-weight: bold;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
  line-height: 1.4;
}

/* 召见菜单 */
.meet-menu {
  background: var(--paper);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 24rpx;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  z-index: 1000;
}

.meet-menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--red);
  text-align: center;
  margin-bottom: 20rpx;
}

.meet-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.meet-option {
  border: 2rpx solid var(--gold-light);
  border-radius: 12rpx;
  padding: 16rpx;
}

.meet-option.disabled {
  opacity: 0.5;
}

.meet-char-name {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.meet-char-status {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.meet-actions {
  display: flex;
  gap: 12rpx;
}

/* 挑战弹窗 */
.challenge-modal {
  max-width: 640rpx;
}

.challenge-intro {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text);
  margin-bottom: 20rpx;
}

.challenge-progress {
  font-size: 24rpx;
  color: var(--gold);
  margin-bottom: 16rpx;
  text-align: center;
}

.challenge-question {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.challenge-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.challenge-option {
  text-align: left;
  padding: 20rpx;
  font-size: 28rpx;
}

.challenge-result {
  text-align: center;
}

.result-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--red);
  margin-bottom: 12rpx;
}

.result-score {
  font-size: 28rpx;
  color: var(--gold);
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

/* 结局页 */
.ending-section {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--paper);
  z-index: 500;
  overflow-y: auto;
  padding: 40rpx;
}

.ending-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100%;
}

.ending-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--gold);
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
}

.ending-subtitle {
  font-size: 40rpx;
  color: var(--red);
  font-weight: bold;
  margin-bottom: 16rpx;
}

.posthumous-title {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--gold);
  border: 4rpx solid var(--gold);
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  background: var(--black);
}

.summary-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  text-align: center;
  max-width: 600rpx;
  margin-bottom: 32rpx;
}

.final-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.final-stat {
  text-align: center;
  background: var(--black-light);
  border: 2rpx solid var(--gold);
  border-radius: 12rpx;
  padding: 16rpx;
}

.final-stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--gold);
}

.final-stat-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.ending-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  max-width: 480rpx;
}

/* 快捷操作 */
.quick-actions {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  gap: 12rpx;
  z-index: 100;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--black-light);
  border: 2rpx solid var(--gold);
  color: var(--gold);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 存档位 */
.save-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.save-slot {
  border: 2rpx solid var(--gold-light);
  border-radius: 12rpx;
  padding: 16rpx;
  background: var(--black-light);
}

.slot-info {
  margin-bottom: 12rpx;
}

.slot-name {
  font-weight: bold;
  font-size: 28rpx;
  color: var(--text);
}

.slot-meta {
  font-size: 24rpx;
  color: var(--text-light);
}

.slot-actions {
  display: flex;
  gap: 12rpx;
}

/* 危机预警 */
.crisis-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--red);
  color: #fff;
  padding: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  z-index: 1000;
  font-size: 28rpx;
}

/* 小按钮 */
.mini-btn {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  flex: 1;
}

/* 设置弹窗 */
.section-title {
  font-size: 30rpx;
  color: var(--red);
  margin-bottom: 16rpx;
  font-weight: bold;
}
