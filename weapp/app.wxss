/* 凌烟阁密档 - 小程序全局样式 */
page {
  --gold: #c9a227;
  --gold-light: #e8d48b;
  --red: #b22222;
  --red-dark: #8b1a1a;
  --black: #1a1a1a;
  --black-light: #2a2a2a;
  --paper: #f7f3e8;
  --text: #2c2417;
  --text-light: #6b5d4d;

  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Serif SC", serif;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2418 50%, #1a1a1a 100%);
  color: var(--text);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn {
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
  border: 2rpx solid var(--gold);
  background: transparent;
  color: var(--gold);
  font-family: inherit;
}

.btn-primary {
  background: var(--red);
  color: #fff;
  border-color: var(--red-dark);
}

.btn-secondary {
  background: var(--black-light);
  color: var(--gold-light);
  border-color: var(--gold);
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 卡片 */
.card {
  background: var(--paper);
  border: 2rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
}

/* 标题 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--gold);
  letter-spacing: 4rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.5);
}

/* 进度条 */
.progress-bar {
  height: 16rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid var(--gold);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--red), var(--gold));
  transition: width 0.5s ease;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal {
  background: var(--paper);
  border: 4rpx solid var(--gold);
  border-radius: 16rpx;
  padding: 40rpx;
  max-width: 640rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  color: var(--red);
  text-align: center;
  font-weight: bold;
  margin-bottom: 24rpx;
}

/* 隐藏 */
.hidden {
  display: none !important;
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 广告标签 */
.ad-badge {
  display: inline-block;
  background: var(--red);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

/* 提示条 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.8);
  color: var(--gold-light);
  padding: 24rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 2000;
  border: 2rpx solid var(--gold);
}
